@model MovieApp.Web.Models.ReelsFeedViewModel
@{
	ViewData["Title"] = "Reels Feed";
}

<div class="reels-container">
	@if (Model.IsLoading)
	{
			<div class="d-flex justify-content-center align-items-center h-100">
				<div class="spinner-border text-light" style="width: 3rem; height: 3rem;" role="status"></div>
			</div>
	}
	else if (Model.HasError)
	{
			<div class="text-center text-danger p-5 mt-5">
				<i class="bi bi-exclamation-triangle-fill" style="font-size: 3rem;"></i>
				<h4 class="mt-3">@Model.ErrorMessage</h4>
				<a href="@Url.Action("Index")" class="btn btn-outline-danger mt-2">Retry</a>
			</div>
	}
	else
	{
		@foreach (var reel in Model.Reels)
		{
					<div class="reel-item">
						<video loop autoplay playsinline muted
							   onplay="this.startTime = Date.now()"
							   ontimeupdate="updateProgress(@reel.Id, this)"
							   onpause="handleWatch(@reel.Id, this, '@Url.Action("RecordWatch", "ReelsFeed")')"
							   onended="handleWatch(@reel.Id, this, '@Url.Action("RecordWatch", "ReelsFeed")')">
							<source src="@reel.VideoUrl" type="video/mp4">
						</video>

						<!-- Sidebar Actions -->
						<div class="side-actions">
							<button id="like-btn-@reel.Id"
									class="action-btn @(reel.IsLikedByMe ? "btn-danger-active" : "")"
									onclick="toggleLike(@reel.Id, '@Url.Action("Like", "ReelsFeed")')">
								<i class="@(reel.IsLikedByMe ? "bi bi-heart-fill" : "bi bi-heart")"></i>
								<span id="like-count-@reel.Id">@reel.LikeCount</span>
							</button>
						</div>

						<!-- Text Overlay -->
						<div class="video-overlay">
							<p>@reel.Caption</p>
						</div>

						<!-- Progress bar -->
						<div class="reel-progress">
							<div class="reel-progress-fill" id="progress-@reel.Id"></div>
						</div>
					</div>
		}
	}
</div>

@section Scripts {
		<script src="~/js/reels-feed.js" asp-append-version="true"></script>
}

@section Styles {
		<link rel="stylesheet" href="~/css/reels-feed.css" asp-append-version="true" />
}
