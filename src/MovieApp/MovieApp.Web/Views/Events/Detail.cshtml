@model MovieApp.DataLayer.Models.MovieEvent

@{
    ViewData["Title"] = "Event Details";
    var hasTicket = (bool)ViewBag.HasTicket;
    var soldTickets = 0; // Assumption
    var isSoldOut = (Model.Capacity - soldTickets) <= 0;
}

<div class="container mt-5">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4 px-4 mb-4 shadow-sm" role="alert">
            <i class="bi bi-exclamation-octagon-fill me-2"></i>
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-lg overflow-hidden rounded-5">
        <div class="row g-0">
            <div class="col-lg-5">
                <div class="detail-poster-container h-100">
                    <img src="@Model.PosterUrl" class="img-fluid h-100 w-100 object-fit-cover" alt="@Model.Title" onerror="this.src='https://placehold.co/600x900?text=@Model.Title'">
                </div>
            </div>
            <div class="col-lg-7">
                <div class="card-body p-4 p-md-5">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2">Upcoming Event</span>
                        <h5 class="mb-0 text-muted">@Model.DisplayTicketPrice</h5>
                    </div>

                    <h1 class="display-3 fw-bold mb-4">@Model.Title</h1>
                    
                    <div class="event-meta-grid mb-5">
                        <div class="row g-4">
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center">
                                    <div class="icon-circle bg-light text-primary me-3">
                                        <i class="bi bi-calendar-check"></i>
                                    </div>
                                    <div>
                                        <div class="text-muted small">Date & Time</div>
                                        <div class="fw-bold">@Model.DisplayDate</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center">
                                    <div class="icon-circle bg-light text-primary me-3">
                                        <i class="bi bi-geo-alt"></i>
                                    </div>
                                    <div>
                                        <div class="text-muted small">Location</div>
                                        <div class="fw-bold">@Model.Location</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center">
                                    <div class="icon-circle bg-light text-primary me-3">
                                        <i class="bi bi-film"></i>
                                    </div>
                                    <div>
                                        <div class="text-muted small">Featured Movie</div>
                                        <div class="fw-bold">@(Model.Movie?.Title ?? "Special Event")</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center">
                                    <div class="icon-circle bg-light text-primary me-3">
                                        <i class="bi bi-ticket-perforated"></i>
                                    </div>
                                    <div>
                                        <div class="text-muted small">Availability</div>
                                        <div class="fw-bold">@(Model.Capacity - soldTickets) / @Model.Capacity Seats</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <h5 class="fw-bold mb-3">About this Event</h5>
                    <p class="lead text-muted mb-5">@Model.Description</p>

                    <div class="mt-auto">
                        @if (hasTicket)
                        {
                            <div class="alert alert-success rounded-4 d-flex align-items-center py-3 shadow-sm border-0">
                                <i class="bi bi-check-circle-fill h4 mb-0 me-3"></i>
                                <div>
                                    <h6 class="mb-0 fw-bold">Ticket Secured!</h6>
                                    <small>You already hold a ticket for this event. Check your inventory.</small>
                                </div>
                            </div>
                        }
                        else if (isSoldOut)
                        {
                            <button class="btn btn-secondary btn-lg w-100 rounded-pill py-3 disabled shadow-sm">
                                <i class="bi bi-x-circle me-2"></i> Sold Out
                            </button>
                        }
                        else
                        {
                            <form asp-action="BuyTicket" method="post">
                                <input type="hidden" name="eventId" value="@Model.Id" />
                                <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill py-3 shadow-lg purchase-btn">
                                    <i class="bi bi-ticket-detailed-fill me-2"></i> Buy Ticket Now
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .detail-poster-container {
        min-height: 400px;
    }
    .icon-circle {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
    }
    .purchase-btn {
        background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
        border: none;
        font-weight: 700;
        letter-spacing: 0.5px;
        transition: all 0.3s ease;
    }
    .purchase-btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 30px rgba(37, 117, 252, 0.3) !important;
    }
    .rounded-5 {
        border-radius: 2rem !important;
    }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
