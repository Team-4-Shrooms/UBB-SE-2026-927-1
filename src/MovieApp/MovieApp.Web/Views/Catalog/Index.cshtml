@model MovieApp.Web.Models.CatalogIndexViewModel

@{
    ViewData["Title"] = "Movie Catalog";
}

<partial name="_FlashSaleBanner" model="Model.Movies" />

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Movie Catalog</h2>
</div>

<div class="card box-shadow mb-4">
    <div class="card-body bg-light">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label text-muted fw-bold">Search Title</label>
                <input type="text" name="search" value="@Model.Filter.Search" class="form-control" placeholder="Search movies...">
            </div>
            <div class="col-md-3">
                <label class="form-label text-muted fw-bold">Genre</label>
                <select name="genre" class="form-select">
                    <option value="">All Genres</option>
                    @foreach (var genre in Model.Genres)
                    {
                        if (Model.Filter.Genre == genre)
                        {
                            <option value="@genre" selected>@genre</option>
                        }
                        else
                        {
                            <option value="@genre">@genre</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label text-muted fw-bold">Min Rating</label>
                <input type="number" step="0.1" min="0" max="10" name="minRating" value="@Model.Filter.MinRating" class="form-control" placeholder="e.g. 8.0">
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Filter</button>
            </div>
        </form>
    </div>
</div>

@if (!Model.Movies.Any())
{
    <div class="alert alert-info text-center py-5">
        <h5 class="mb-0">No movies found matching your search criteria.</h5>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var movie in Model.Movies)
        {
            <div class="col">
                <div class="card h-100 box-shadow">
                    @if (string.IsNullOrEmpty(movie.PosterUrl))
                    {
                        <div class="bg-secondary text-white d-flex align-items-center justify-content-center" style="height: 350px;">
                            <span>No Poster</span>
                        </div>
                    }
                    else
                    {
                        <img src="@movie.PosterUrl" class="card-img-top" alt="@movie.Title" style="height: 350px; object-fit: cover;">
                    }

                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title fw-bold mb-0">@movie.Title (@movie.ReleaseYear)</h5>
                            <span class="badge bg-warning text-dark"><i class="bi bi-star-fill"></i> @movie.Rating.ToString("0.0")</span>
                        </div>
                        
                        <div class="mb-3">
                            <span class="badge bg-secondary">@movie.Genre</span>
                            @if (movie.HasActiveSale)
                            {
                                <span class="badge bg-danger ms-1">Sale</span>
                            }
                        </div>
                        
                        <div class="mt-auto d-flex justify-content-between align-items-center">
                            <div>
                                @if (movie.HasActiveSale)
                                {
                                    <span class="fs-5 fw-bold text-danger">$@movie.DiscountedPriceText</span>
                                    <del class="text-muted small ms-1">$@movie.OriginalPriceText</del>
                                }
                                else
                                {
                                    <span class="fs-5 fw-bold">$@movie.OriginalPriceText</span>
                                }
                            </div>
                            <a asp-action="Detail" asp-route-id="@movie.Id" class="btn btn-sm btn-outline-primary">View Details</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
