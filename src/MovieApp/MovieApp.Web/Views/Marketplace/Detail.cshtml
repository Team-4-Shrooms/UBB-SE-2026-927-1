@model MovieApp.DataLayer.Models.Equipment

@{
    ViewData["Title"] = "Equipment Details";
    var currentUserId = (int)ViewBag.CurrentUserId;
    var isSeller = Model.Seller?.Id == currentUserId;
}

<div class="container mt-5">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-pill px-4 mb-4 shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-5">
        <div class="col-lg-6">
            <div class="detail-img-wrapper shadow-lg rounded-4 overflow-hidden d-flex align-items-center justify-content-center">
                <img src="@Model.ImageUrl" class="img-fluid mw-100 mh-100 object-fit-contain" alt="@Model.Title" onerror="this.src='https://placehold.co/800x600?text=@Model.Title'">
            </div>
        </div>
        <div class="col-lg-6">
            <div class="ps-lg-4">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a asp-action="Index">Marketplace</a></li>
                        <li class="breadcrumb-item active" aria-current="page">@Model.Category</li>
                    </ol>
                </nav>

                <h1 class="display-4 fw-bold mb-3">@Model.Title</h1>
                
                <div class="d-flex align-items-center mb-4">
                    <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2 me-2">@Model.Condition</span>
                    <span class="text-muted small">Listed by <span class="fw-bold">@(Model.Seller?.Username ?? "Unknown")</span></span>
                </div>

                <div class="price-container mb-4">
                    <h2 class="display-5 fw-bold text-primary">@Model.Price.ToString("C")</h2>
                </div>

                <div class="description-container mb-5">
                    <h5 class="fw-bold">Description</h5>
                    <p class="lead text-muted">@Model.Description</p>
                </div>

                <div class="action-container">
                    @if (isSeller)
                    {
                        <div class="alert alert-info rounded-pill px-4 shadow-sm border-0 d-inline-block">
                            <i class="bi bi-person-check-fill me-2"></i>
                            <strong>Already owned</strong> (You are the seller)
                        </div>
                    }
                    else
                    {
                        <form asp-action="Buy" asp-route-id="@Model.Id" method="post">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 py-3 shadow buy-btn">
                                <i class="bi bi-cart-fill me-2"></i> Purchase Equipment
                            </button>
                        </form>
                    }
                </div>
                
                <div class="mt-5 p-4 bg-light rounded-4 border-0">
                    <div class="row text-center g-4">
                        <div class="col-4">
                            <div class="h5 mb-1"><i class="bi bi-shield-check"></i></div>
                            <div class="small text-muted">Secure Transaction</div>
                        </div>
                        <div class="col-4">
                            <div class="h5 mb-1"><i class="bi bi-truck"></i></div>
                            <div class="small text-muted">Fast Shipping</div>
                        </div>
                        <div class="col-4">
                            <div class="h5 mb-1"><i class="bi bi-arrow-counterclockwise"></i></div>
                            <div class="small text-muted">7 Day Returns</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .detail-img-wrapper {
        aspect-ratio: 4/3;
        background-color: #1a1a1a;
        transition: transform 0.3s ease;
    }
    .detail-img-wrapper:hover {
        transform: scale(1.02);
    }
    .buy-btn {
        background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
        border: none;
        transition: all 0.3s ease;
    }
    .buy-btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(37, 117, 252, 0.3) !important;
    }
    .breadcrumb-item a {
        text-decoration: none;
        color: #6c757d;
    }
    .breadcrumb-item.active {
        color: #212529;
        font-weight: 600;
    }
</style>

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
