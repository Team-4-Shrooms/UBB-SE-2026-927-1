@using MovieApp.DataLayer.Models
@{
    ViewData["Title"] = "Wallet";
    var balance = (decimal)(ViewBag.Balance ?? 0m);
    var transactions = (List<Transaction>?)ViewBag.Transactions ?? new List<Transaction>();
    int currentPage = (int)(ViewBag.CurrentPage ?? 1);
    bool hasNextPage = (bool)(ViewBag.HasNextPage ?? false);
}

<h1 class="mb-4">Wallet</h1>

<div class="card bg-primary text-white mb-4" style="max-width: 400px;">
    <div class="card-body">
        <h6 class="card-subtitle mb-2 text-white-50">Your Balance</h6>
        <h2 class="card-title mb-0">@balance.ToString("C")</h2>
    </div>
</div>

<h4 class="mb-3">Transaction History</h4>

@if (transactions.Count == 0 && currentPage == 1)
{
    <div class="text-center py-5 text-muted">
        <p class="lead">No transactions yet.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Description</th>
                    <th class="text-end">Amount</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tx in transactions)
                {
                    var isPositive = tx.Amount >= 0;
                    var description = tx.Movie?.Title
                        ?? tx.Equipment?.Title
                        ?? tx.Event?.Title
                        ?? tx.ShippingAddress
                        ?? "—";
                    <tr>
                        <td>@tx.Timestamp.ToString("MMM dd, yyyy HH:mm")</td>
                        <td><span class="badge bg-secondary">@tx.Type</span></td>
                        <td>@description</td>
                        <td class="text-end @(isPositive ? "text-success" : "text-danger")">
                            @(isPositive ? "+" : "")@tx.Amount.ToString("C")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <nav aria-label="Transaction pagination">
        <ul class="pagination">
            <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)">Previous</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">Page @currentPage</span>
            </li>
            <li class="page-item @(!hasNextPage ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)">Next</a>
            </li>
        </ul>
    </nav>
}
