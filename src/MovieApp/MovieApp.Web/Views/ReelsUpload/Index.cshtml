@model MovieApp.Web.ViewModels.ReelUpload.ReelUploadForm

@{
    ViewData["Title"] = "Upload Reel";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h2 class="mb-4 text-center">@ViewData["Title"]</h2>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger shadow-sm">
                    <div asp-validation-summary="All" class="mb-0"></div>
                </div>
            }

            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white fw-bold">
                    Reel Details
                </div>
                <div class="card-body p-4">
                    <form asp-action="Upload" asp-controller="ReelsUpload" enctype="multipart/form-data" method="post">
                        
                        <div class="mb-4">
                            <label class="form-label fw-bold">Video File (.mp4)</label>
                            <input type="file" name="videoFile" class="form-control form-control-lg" accept=".mp4,video/mp4" required />
                            <div class="form-text">Must be a valid MP4 file (Max 60 seconds / 100MB).</div>
                        </div>

						<div class="mb-3">
							<label asp-for="MusicTrackId" class="form-label fw-bold">Background Music (Optional)</label>
							<select asp-for="MusicTrackId" class="form-select">
								<option value="">-- No Music --</option>
								<option value="1">Lofi Chill Beat</option>
								<option value="2">Action Trailer Theme</option>
								<option value="3">Dramatic Orchestral</option>
							</select>
						</div>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-bold">Reel Title</label>
                            <input asp-for="Title" class="form-control" placeholder="e.g., Awesome Scene" required />
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold">Caption</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Write a compelling caption..."></textarea>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">Upload Reel</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
