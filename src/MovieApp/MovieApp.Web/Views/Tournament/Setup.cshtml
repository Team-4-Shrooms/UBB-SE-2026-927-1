@model MovieApp.Web.Models.TournamentSetupViewModel
@{
    ViewData["Title"] = "Tournament Setup";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <h2 class="mb-4">Movie Tournament</h2>
            <p class="lead">Select your tournament size to begin the showdown.</p>

            <form asp-action="Start" method="post" class="card p-4 shadow-sm">
                <div class="mb-4">
                    <label class="form-label fw-bold">Select Bracket Size</label>
                    <select asp-for="PoolSize" class="form-select form-select-lg">
                        <option value="4">4 Movies (Quick Game)</option>
                        <option value="8" selected>8 Movies (Standard Bracket)</option>
                        <option value="16">16 Movies (Epic Showdown)</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-primary btn-lg w-100">Start Tournament</button>
            </form>
        </div>
    </div>
</div>
