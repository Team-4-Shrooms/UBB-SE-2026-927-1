@model MovieApp.Web.Models.TournamentMatchViewModel
@{
    ViewData["Title"] = "Tournament Match";
}

<div class="container mt-4">
    <div class="text-center mb-5">
        <h2>Round @Model.CurrentRound</h2>
        <p class="text-muted">Click on the movie you want to advance to the next round!</p>
    </div>

    <div class="row justify-content-center align-items-center">
        <div class="col-md-5 col-sm-6 mb-4">
            <form asp-action="PickWinner" method="post">
                <input type="hidden" name="winnerMovieId" value="@Model.Left.Id" />
                <button type="submit" class="btn p-0 border-0 text-start w-100 tournament-card">
                    <div class="card h-100 shadow-sm border-primary">
                        <img src="@Model.Left.PosterUrl" class="card-img-top" alt="@Model.Left.Title" style="height: 500px; object-fit: cover;">
                        <div class="card-body text-center bg-light">
                            <h5 class="card-title">@Model.Left.Title</h5>
                            <span class="badge bg-secondary">@Model.Left.ReleaseYear</span>
                            <span class="badge bg-primary">@Model.Left.PrimaryGenre</span>
                        </div>
                    </div>
                </button>
            </form>
        </div>

        <div class="col-md-2 col-sm-12 text-center mb-4">
            <h1 class="display-4 fw-bold text-danger">VS</h1>
        </div>

        <div class="col-md-5 col-sm-6 mb-4">
            <form asp-action="PickWinner" method="post">
                <input type="hidden" name="winnerMovieId" value="@Model.Right.Id" />
                <button type="submit" class="btn p-0 border-0 text-start w-100 tournament-card">
                    <div class="card h-100 shadow-sm border-danger">
                        <img src="@Model.Right.PosterUrl" class="card-img-top" alt="@Model.Right.Title" style="height: 500px; object-fit: cover;">
                        <div class="card-body text-center bg-light">
                            <h5 class="card-title">@Model.Right.Title</h5>
                            <span class="badge bg-secondary">@Model.Right.ReleaseYear</span>
                            <span class="badge bg-danger">@Model.Right.PrimaryGenre</span>
                        </div>
                    </div>
                </button>
            </form>
        </div>
    </div>

    <div class="text-center mt-4">
        <form asp-action="Reset" method="post">
            <button type="submit" class="btn btn-outline-secondary">Quit Tournament</button>
        </form>
    </div>
</div>

<style>
    .tournament-card { transition: transform 0.2s ease-in-out; }
    .tournament-card:hover { transform: scale(1.03); cursor: pointer; }
</style>
