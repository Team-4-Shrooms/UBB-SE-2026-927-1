@model MovieApp.Web.Models.TournamentWinnerViewModel
@{
    ViewData["Title"] = "Tournament Champion";
}

<div class="container mt-5">
    <div class="text-center mb-4">
        <h1 class="display-4 text-warning fw-bold">🏆 Champion 🏆</h1>
        <p class="lead">The people have spoken! Here is your ultimate winner.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow border-warning border-3">
                <img src="@Model.Winner.PosterUrl" class="card-img-top" alt="@Model.Winner.Title" style="height: 600px; object-fit: cover;">
                <div class="card-body text-center bg-light">
                    <h2 class="card-title">@Model.Winner.Title</h2>
                    <p class="card-text text-muted">@Model.Winner.ReleaseYear • @Model.Winner.PrimaryGenre</p>
                </div>
            </div>
        </div>
    </div>

    <div class="text-center mt-5">
        <form asp-action="Reset" method="post">
            <button type="submit" class="btn btn-success btn-lg px-5">Play Again</button>
        </form>
    </div>
</div>
