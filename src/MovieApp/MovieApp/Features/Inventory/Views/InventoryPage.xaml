<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MovieApp.Features.Inventory.Views.InventoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MovieApp.DataLayer.Models"
    mc:Ignorable="d">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="My Inventory" FontSize="28" FontWeight="Bold" Foreground="White"/>

        <Pivot Grid.Row="1">
            <PivotItem Header="Movies">
                <GridView x:Name="MoviesGrid"
                          SelectionMode="None"
                          IsItemClickEnabled="True"
                          ItemClick="MoviesGrid_ItemClick"
                          Padding="0">
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Margin" Value="8"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="models:Movie">
                            <Border Background="#2A2A2A"
                                    CornerRadius="10"
                                    Padding="0"
                                    Width="200"
                                    BorderBrush="#404040"
                                    BorderThickness="1">
                                <StackPanel Spacing="8" Padding="10">
                                    <Border Height="260" Background="#1A1A1A" CornerRadius="6">
                                        <Image Source="{x:Bind PosterUrl}" Stretch="UniformToFill"/>
                                    </Border>
                                    <TextBlock Text="{x:Bind Title}" Foreground="White" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxLines="2" TextWrapping="Wrap"/>
                                    <Button Content="Remove" HorizontalAlignment="Right" Click="RemoveMovie_Click" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </PivotItem>
            <PivotItem Header="Tickets">
                <GridView x:Name="TicketsGrid" SelectionMode="None" Padding="0">
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Margin" Value="8"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="models:OwnedTicket">
                            <Border Background="#252525" CornerRadius="10" Padding="14" Width="300">
                                <StackPanel>
                                    <Border Height="150" Background="#1A1A1A" CornerRadius="6">
                                        <Image Source="{x:Bind Event.PosterUrl}" Stretch="UniformToFill"/>
                                    </Border>
                                    <TextBlock Text="{x:Bind Event.Title}" Foreground="White" FontSize="16" FontWeight="Bold" TextWrapping="Wrap"/>
                                    <TextBlock Text="{x:Bind Event.DisplayDate}" Foreground="#CCCCCC" FontSize="12"/>
                                    <TextBlock Text="{x:Bind Event.DisplayTicketPrice}" Foreground="#1DB954" FontWeight="SemiBold"/>
                                    <Button Content="Remove" HorizontalAlignment="Right" Click="RemoveTicket_Click" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </PivotItem>
            <PivotItem Header="Equipment">
                <GridView x:Name="EquipmentGrid" SelectionMode="None" Padding="0">
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Margin" Value="8"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="models:Equipment">
                            <Border Background="#2A2A2A" CornerRadius="10" Padding="12" Width="300">
                                <StackPanel>
                                    <Border Height="160" Background="#1A1A1A" CornerRadius="6">
                                        <Image Source="{x:Bind ImageUrl}" Stretch="UniformToFill"/>
                                    </Border>
                                    <TextBlock Text="{x:Bind Title}" Foreground="White" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                    <TextBlock Text="{x:Bind Category}" Foreground="#CCCCCC" FontSize="12"/>
                                    <TextBlock Text="{x:Bind Price}" Foreground="#1DB954" FontWeight="SemiBold"/>
                                    <Button Content="Remove" HorizontalAlignment="Right" Click="RemoveEquipment_Click" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
