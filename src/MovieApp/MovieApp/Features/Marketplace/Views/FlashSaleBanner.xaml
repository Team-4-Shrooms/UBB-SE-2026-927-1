<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MovieApp.Features.Marketplace.Views.FlashSaleBanner"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="BannerRoot">

    <Border x:Name="BannerBorder" 
            Background="#D32F2F" 
            Padding="10"
            Visibility="{x:Bind ViewModel.BannerVisibility, Mode=OneWay}">

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
            <TextBlock Text="FLASH SALE ENDS IN:" Foreground="White" FontWeight="Bold"/>

            <TextBlock x:Name="TimerText" 
                       Text="{x:Bind ViewModel.TimerText, Mode=OneWay}" 
                       Foreground="White" 
                       FontWeight="Bold"/>
        </StackPanel>
    </Border>
</UserControl>
